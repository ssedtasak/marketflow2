{
  "name": "@marketflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply marketflow-db --local",
    "lint": "eslint ."
  },
  "dependencies": {
    "@marketflow/shared": "workspace:*",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.6.0",
    "resend": "^6.10.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240800.0",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.80.0"
  }
}
